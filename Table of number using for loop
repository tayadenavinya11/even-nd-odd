//TITLE: PROGRAM TO PRINT THE MULTIPLICATION TABLE OF A NUMBER USING A FOR LOOP

#include<stdio.h>

int main()
{
    int n, i;

    printf("Enter number: ");
    scanf("%d", &n);

    for(i = 1; i <= 10; i++)
    {
        printf("%d * %d = %d\n", n, i, n * i);
    }

    return 0;
}
