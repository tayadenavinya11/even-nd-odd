//TITLE: PROGRAM TO FIND FACTORIAL OF A NUMBER USING RECURSION

#include <stdio.h>

int factorial(int n)
{
    if(n == 0 || n == 1)
    {
        return 1;
    }
    else
    {
        return n * factorial(n - 1);
    }
}

int main()
{
    int n;

    printf("Enter number:\t");
    scanf("%d", &n);

    printf("Factorial = %d", factorial(n));

    return 0;
}
