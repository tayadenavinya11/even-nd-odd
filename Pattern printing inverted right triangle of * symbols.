//TITLE: PATTERN PRINTING

#include<stdio.h>

int main()
{
    int i, j, k;

    for(i = 1; i <= 3; i++)
    {
        for(k = 1; k < i; k++)
        {
            printf("\t");
        }

        for(j = i; j <= 3; j++)
        {
            printf("*\t");
        }

        printf("\n");
    }

    return 0;
}
