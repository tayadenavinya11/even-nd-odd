//TITLE: PROGRAM TO FIND THE GRADE OF A STUDENT USING IF-ELSE STATEMENTS

#include<stdio.h>

int main()
{
    int marks;

    printf("Enter Marks(0-100): ");
    scanf("%d", &marks);

    if(marks < 0 || marks > 100)
    {
        printf("Invalid marks\n");
    }
    else if(marks >= 0 && marks < 30)
    {
        printf("C\n");
    }
    else if(marks >= 30 && marks < 70)
    {
        printf("B\n");
    }
    else if(marks >= 70 && marks < 90)
    {
        printf("A\n");
    }
    else
    {
        printf("A+\n");
    }

    printf("Thank you!\n");

    return 0;
}
