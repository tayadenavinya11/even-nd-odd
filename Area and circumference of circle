/* to calculate area &circumference of a circle if diameter input to the keyboard
name:- navinya vijay tayade
date:-1/4/26 */
#include<stdio.h>
int main()
{
    float d,a,c,r;
    printf("enter diameter =\t");
    scanf("%f",&d);
    r = d/2;
    a = 3.14*r*r;
    printf("\n area of circle is %f",a);
    c = 2*3.14*r;
    printf("\n circumference of circle is %f",c);
    return 0;
}
